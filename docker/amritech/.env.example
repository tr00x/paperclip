# =============================================================================
# AmriTech Docker Stack — Environment Variables
# =============================================================================

# --- Paperclip ---
PAPERCLIP_PORT=4444
PAPERCLIP_PG_PASSWORD=your_postgres_password_here
PAPERCLIP_PUBLIC_URL=https://your-domain.example.com

# --- Twenty CRM ---
TWENTY_PG_PASSWORD=your_postgres_password_here
TWENTY_APP_SECRET=your_app_secret_here
TWENTY_SERVER_URL=https://crm.your-domain.example.com
TWENTY_API_KEY=your_twenty_api_key_here

# --- SMTP ---
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=agent@your-domain.example.com
SMTP_PASSWORD=your_smtp_password_here

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
COMPANY_ID=your_company_uuid_here

# --- Cloudflare Tunnel Tokens ---
CF_TUNNEL_TG_TOKEN=your_cloudflare_tunnel_token_here
CF_TUNNEL_DISPATCH_TOKEN=your_cloudflare_tunnel_token_here
CF_TUNNEL_CRM_TOKEN=your_cloudflare_tunnel_token_here
